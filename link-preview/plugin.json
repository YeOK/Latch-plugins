{
    "name": "Link preview",
    "slug": "link-preview",
    "version": "1.0.0",
    "min_latch_version": "0.4.4",
    "description": "Rich link cards and optional video embeds for standalone URLs in posts.",
    "hooks": [
        "route.register",
        "theme.assets",
        "post.format.link",
        "post.format.after",
        "csp.img_src",
        "csp.frame_src",
        "post.delete"
    ],
    "database": {
        "enabled": true
    },
    "settings_schema": [
        {
            "key": "enabled",
            "type": "boolean",
            "label": "Enable link previews",
            "default": true
        },
        {
            "key": "embed_videos",
            "type": "boolean",
            "label": "Embed YouTube and Vimeo",
            "description": "Show an inline player for standalone video links (otherwise thumbnail card only).",
            "default": true
        },
        {
            "key": "max_previews",
            "type": "integer",
            "label": "Max previews per post",
            "description": "Standalone URL cards expanded per post body (additional URLs stay plain links).",
            "default": 3,
            "min": 1,
            "max": 10
        },
        {
            "key": "fetch_timeout",
            "type": "integer",
            "label": "Fetch timeout (seconds)",
            "default": 5,
            "min": 2,
            "max": 15
        },
        {
            "key": "cache_ttl_hours",
            "type": "integer",
            "label": "Cache TTL (hours)",
            "description": "How long fetched Open Graph metadata is reused.",
            "default": 168,
            "min": 1,
            "max": 720
        }
    ],
    "permissions": {
        "filesystem": [
            "thumbs"
        ],
        "network": true,
        "config": []
    }
}
{
    "name": "Git release widget",
    "slug": "git-release",
    "version": "1.2.1",
    "min_latch_version": "0.4.6",
    "description": "Latest GitHub release card on the home page via client-mode guest cache (JSON hydrate).",
    "hooks": [
        "home.before_boards",
        "route.register",
        "theme.assets",
        "theme.scripts"
    ],
    "cache": {
        "guest_page": "client",
        "invalidate_on": [
            "plugin"
        ],
        "client": "/plugin/git-release/widget.json"
    },
    "settings_schema": [
        {
            "key": "github_repo",
            "type": "string",
            "label": "GitHub repository",
            "description": "Public repository as owner/name (e.g. YeOK/Latch or your-org/your-project). Uses the GitHub REST API — no token required for public repos.",
            "default": "YeOK/Latch"
        },
        {
            "key": "heading",
            "type": "string",
            "label": "Card heading",
            "default": "Latest release"
        },
        {
            "key": "max_age_seconds",
            "type": "select",
            "label": "Release cache TTL",
            "description": "How long to cache GitHub API responses server-side and browser cache for widget.json. Purge the release cache after changing the repository.",
            "default": "300",
            "options": [
                {
                    "value": "300",
                    "label": "5 minutes"
                },
                {
                    "value": "600",
                    "label": "10 minutes"
                },
                {
                    "value": "900",
                    "label": "15 minutes"
                },
                {
                    "value": "1800",
                    "label": "30 minutes"
                },
                {
                    "value": "3600",
                    "label": "1 hour"
                }
            ]
        }
    ],
    "permissions": {
        "filesystem": [
            "storage/plugins/git-release"
        ],
        "network": [
            "api.github.com"
        ],
        "config": []
    }
}